# ═══════════════════════════════════════════════════════
# Venture Autopsy — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════

# ──── Supabase ────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──── Band ────
# Set to "mock" to use the mock adapter during development
BAND_API_KEY=mock
BAND_OWNER_HANDLE=your-handle

# ──── Gemini (Google AI Studio) ────
GEMINI_API_KEY=your-gemini-api-key

# ──── AI/ML API (aimlapi.com) ────
AIML_API_KEY=your-aiml-api-key

# ──── Featherless ────
FEATHERLESS_API_KEY=your-featherless-api-key

# ──── GitHub (optional, increases rate limit) ────
GITHUB_TOKEN=your-github-pat

# ──── Server ────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]
